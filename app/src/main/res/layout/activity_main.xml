<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#FAF8FF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MÁY TÍNH ĐƠN GIẢN"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#3F51B5"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="40dp"/>

    <EditText
        android:id="@+id/edtSoA"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập số A"
        android:inputType="numberDecimal"
        android:layout_marginBottom="15dp"/>

    <EditText
        android:id="@+id/edtSoB"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập số B"
        android:inputType="numberDecimal"
        android:layout_marginBottom="40dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="40dp">

        <Button
            android:id="@+id/btnCong"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:text="+"
            android:textSize="20sp"
            android:layout_margin="8dp"
            android:backgroundTint="#6750A4"
            app:cornerRadius="50dp"/>

        <Button
            android:id="@+id/btnTru"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:text="-"
            android:textSize="20sp"
            android:layout_margin="8dp"
            android:backgroundTint="#6750A4"
            app:cornerRadius="50dp"/>

        <Button
            android:id="@+id/btnNhan"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:text="*"
            android:textSize="20sp"
            android:layout_margin="8dp"
            android:backgroundTint="#6750A4"
            app:cornerRadius="50dp"/>

        <Button
            android:id="@+id/btnChia"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:text="/"
            android:textSize="20sp"
            android:layout_margin="8dp"
            android:backgroundTint="#6750A4"
            app:cornerRadius="50dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvKetQua"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kết quả:"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FF5722"
        android:gravity="center"/>

</LinearLayout>